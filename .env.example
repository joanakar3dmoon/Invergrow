# ── Gemini AI ─────────────────────────────────────────────────
# Clave de la API de Google Gemini para generación de contenido IA
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── Supabase (base de datos persistente) ──────────────────────
# URL de tu proyecto Supabase
SUPABASE_URL="https://tolzqxflecqbjdefohom.supabase.co"
# Service Role Key (con permisos de escritura)
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_KEY"

# ── PayPal Payouts API (retiros reales propietario) ────────────
# Client ID de tu app PayPal Developer
PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
# Secret de tu app PayPal Developer  
PAYPAL_SECRET="YOUR_PAYPAL_SECRET"
# "sandbox" para pruebas, "live" para producción real
PAYPAL_ENV="sandbox"

# ── Admin ─────────────────────────────────────────────────────
# Código PIN del propietario para acceder al panel de retiros
ADMIN_CODE="joan123"

# ── App URL ───────────────────────────────────────────────────
APP_URL="https://invergrow.vercel.app"
